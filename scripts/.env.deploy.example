# Copy this file to scripts/.env.deploy and fill in your real values.
# scripts/.env.deploy is gitignored and must NEVER be committed.

# Docker Hub image (no tag) -- the tag is supplied per-deploy as the script argument.
IMAGE=mukund146/chronologbackend

# The Google Cloud VM you SSH into.
VM_HOST= 35.221.61.6      # e.g. 34.x.x.x  (a GCP static IP avoids redeploys on reboot)
VM_USER=YOUR_SSH_USER

# Directory on the VM that contains docker-compose.yml AND backend/.env
# (env_file: backend/.env is resolved relative to this path).
VM_PATH=/home/YOUR_SSH_USER/chronolog

# Optional: path to the private key for SSH/SCP. Leave blank to use your ssh-agent / default key.
SSH_KEY=
